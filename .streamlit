[theme]
# Fija el tema en "claro" siempre. Sin esto, Streamlit sigue el modo
# claro/oscuro del sistema operativo (incluido el cambio automático de
# macOS según la hora del día), lo que rompe el contraste de colores
# de JuriSync porque el CSS personalizado asume siempre fondo claro.
base = "light"
primaryColor = "#0052cc"
backgroundColor = "#f4f5f7"
secondaryBackgroundColor = "#ffffff"
textColor = "#172b4d"
font = "sans serif"
 
